{
  "expo": {
    "name": "Infocascade",
    "slug": "Infocascade",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon-custom.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon-custom.png",
      "supportsTablet": true,
      "requireFullScreen": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F1F3C",
        "foregroundImage": "./assets/images/android-icon-foreground-custom.png",
        "backgroundImage": "./assets/images/android-icon-background-solid.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "WAKE_LOCK",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.kiranjeet28.Infocascade"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ],
            "useLegacyPackaging": true,
            "enableBundleCompression": true,
            "minSdkVersion": 24,
            "targetSdkVersion": 34,
            "compileSdkVersion": 34
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "backgroundImage": "./assets/images/splash-light.png",
          "backgroundImageScale": "cover",
          "android": {
            "image": "./assets/images/splash-light.png",
            "imageWidth": 200
          },
          "ios": {
            "image": "./assets/images/splash-light.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#6C63FF",
          "defaultChannel": "class-notifications",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "883f5977-8834-40d5-87d7-ebb18bd9a885"
      }
    },
    "owner": "kiranjeet28"
  }
}
